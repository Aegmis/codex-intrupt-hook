{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/intrupt_hook.py",
            "timeout": 630,
            "statusMessage": "Awaiting intrupt approval"
          }
        ]
      }
    ]
  }
}
